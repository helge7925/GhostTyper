# Database
DB_USER=transkription
DB_PASSWORD=change-me
DB_NAME=transkription
DATABASE_URL=postgresql://transkription:change-me@transkription-db:5432/transkription

# NextAuth
NEXTAUTH_SECRET=generate-a-random-secret
NEXTAUTH_URL=http://localhost:3000
AUTH_CREDENTIALS_ENABLED=false
OIDC_PROVIDER_NAME=Single Sign-On
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
DB_INIT_SECRET=separate-db-init-secret
SETTINGS_ENCRYPTION_KEY=separate-settings-encryption-key
ENABLE_DB_INIT_API=false
PDF_CHROMIUM_PATH=/usr/bin/chromium-browser
PDF_CHROMIUM_NO_SANDBOX=false
PDF_EXPORT_MAX_CONCURRENCY=2
PDF_EXPORT_QUEUE_TIMEOUT_MS=5000
TRANSCRIPTION_WORKER_CONCURRENCY=1
TRANSCRIPTION_WORKER_SCAN_INTERVAL_MS=8000
TRANSCRIPTION_WORKER_SCAN_BATCH=20
RATE_LIMIT_STORE=db
RATE_LIMIT_TRUST_PROXY=false
MAINTENANCE_IP_ALLOWLIST=
DB_CONNECTION_TIMEOUT_MS=5000
HTTP_CLIENT_TIMEOUT_MS=30000
HEALTH_DETAILS_PUBLIC=false
HEALTH_DETAILS_SECRET=
LOG_FORMAT=json
LOG_LEVEL=info

# Optional upload malware scan
UPLOAD_VIRUS_SCAN_MODE=command
UPLOAD_VIRUS_SCAN_CMD=clamscan --no-summary {file}
UPLOAD_VIRUS_SCAN_FAIL_OPEN=false
UPLOAD_VIRUS_SCAN_TIMEOUT_MS=20000

# API
NEXT_PUBLIC_API_URL=/api

# Mistral AI
MISTRAL_API_KEY=your-mistral-api-key-here

# Google Gemini
GEMINI_API_KEY=your-google-api-key-here

# Vexa Remote-Meeting integration (opt-in).
#
# To run Vexa Lite alongside GhostTyper, set COMPOSE_PROFILES=vexa and fill
# the variables below. Without the profile, none of these are read and the
# remote-meeting feature stays dormant — the in-app toggle in
# Settings → Integrationen → Vexa controls the second tier.
#
# Generate secrets with: openssl rand -hex 32
COMPOSE_PROFILES=
RECONCILE_API_SECRET=

# Server-side fallback URL used by GhostTyper when an org leaves the Vexa
# base URL empty in the integration settings. Defaults to the in-compose
# service name; only override for external Vexa deployments.
VEXA_BASE_URL=http://vexa-lite:8056

# Container image for the Vexa-Lite bot. Empty / unset = upstream
# Vexa-AI image (Google Meet, Microsoft Teams, Zoom only). To enable
# Nextcloud Talk support, set this to the forked image built by
# helge7925/vexa, e.g.:
#   VEXA_LITE_IMAGE=ghcr.io/helge7925/vexa-bot-talk:0.10.0-talk.1
# The fork tracks upstream and adds a fourth platform adapter; see
# https://github.com/helge7925/vexa/blob/feat/nextcloud-talk-adapter/UPSTREAM-SYNC.md
VEXA_LITE_IMAGE=

# Vexa-Dashboard (Operator-Tool) — Host-Port für die im vexa-lite-Image
# eingebaute Next.js-Dashboard-UI (Bot-Health, VNC, Live-Transcript).
# Standard-Bind ist 127.0.0.1, also nur lokal vom Server aus erreichbar
# (per SSH-Tunnel zugreifbar). Auth läuft über Vexa's admin-api-Token,
# NICHT über GhostTyper-NextAuth — also bewusst kein End-User-Tool.
VEXA_DASHBOARD_HOST_PORT=3300

# Bridge upstream override. Empty = default to Mistral Voxtral. Only set
# this if you want to point Vexa at a different Whisper-compatible API
# (must accept multipart POST /v1/audio/transcriptions with file/model/
# language and return segments with start/end/text/speaker_id).
VEXA_TRANSCRIPTION_URL=
# Legacy upstream-token fallback used by the bridge if MISTRAL_API_KEY is
# not set. Prefer leaving this empty and using MISTRAL_API_KEY (above).
VEXA_TRANSCRIPTION_TOKEN=

# Admin token for the Vexa container itself. Generate fresh:
#   openssl rand -hex 32
VEXA_ADMIN_API_TOKEN=

# Shared secret between webapp and the fireworks-bridge container. Lets
# the bridge fetch the current Mistral Voxtral key (and workspace context
# bias) set in the admin UI at runtime.
#   openssl rand -hex 32
BRIDGE_SHARED_SECRET=
