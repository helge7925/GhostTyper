# Database
DB_USER=transkription
DB_PASSWORD=change-me
DB_NAME=transkription
DATABASE_URL=postgresql://transkription:change-me@transkription-db:5432/transkription

# NextAuth
NEXTAUTH_SECRET=generate-a-random-secret
NEXTAUTH_URL=http://localhost:3000
AUTH_CREDENTIALS_ENABLED=false
OIDC_PROVIDER_NAME=Single Sign-On
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# OIDC account-linking hardening:
# - During migration: set OIDC_LINK_BY_EMAIL=true so existing OIDC users
#   without provider binding get auto-linked on next successful login.
# - After migration window: set OIDC_LINK_BY_EMAIL=false to require explicit
#   provider-account binding (table oidc_account_bindings).
OIDC_LINK_BY_EMAIL=false
# Whether OIDC may auto-create a new `role=user` account when the IdP
# returns a verified email that does not yet exist locally. Only fires
# when OIDC_LINK_BY_EMAIL=true (otherwise unknown emails are rejected
# regardless). Set to `false` if you require admin pre-provisioning of
# every account — the SSO login then fails for unknown emails instead
# of silently creating one.
OIDC_AUTO_PROVISION=true
# Optional allowlist (comma-separated domains). Empty = no domain filter.
# Recommendation for enterprise deployments: set this to your corporate
# domain(s) so SSO cannot be used by personal accounts at the same IdP.
# Example: OIDC_ALLOWED_EMAIL_DOMAINS=romaco.com,subsidiary.example
OIDC_ALLOWED_EMAIL_DOMAINS=
DB_INIT_SECRET=separate-db-init-secret
SETTINGS_ENCRYPTION_KEY=separate-settings-encryption-key
ENABLE_DB_INIT_API=false
PDF_CHROMIUM_PATH=/usr/bin/chromium-browser
PDF_CHROMIUM_NO_SANDBOX=false
PDF_EXPORT_MAX_CONCURRENCY=2
PDF_EXPORT_QUEUE_TIMEOUT_MS=5000
TRANSCRIPTION_WORKER_CONCURRENCY=1
TRANSCRIPTION_WORKER_SCAN_INTERVAL_MS=8000
TRANSCRIPTION_WORKER_SCAN_BATCH=20
RATE_LIMIT_STORE=db
RATE_LIMIT_TRUST_PROXY=false
MAINTENANCE_IP_ALLOWLIST=
DB_CONNECTION_TIMEOUT_MS=5000
HTTP_CLIENT_TIMEOUT_MS=30000
HEALTH_DETAILS_PUBLIC=false
HEALTH_DETAILS_SECRET=
LOG_FORMAT=json
LOG_LEVEL=info

# Optional upload malware scan
UPLOAD_VIRUS_SCAN_MODE=command
UPLOAD_VIRUS_SCAN_CMD=clamscan --no-summary {file}
UPLOAD_VIRUS_SCAN_FAIL_OPEN=false
UPLOAD_VIRUS_SCAN_TIMEOUT_MS=20000

# API
NEXT_PUBLIC_API_URL=/api

# Cortecs AI (primary: transcription, analysis, translation, text optimization)
CORTECS_API_KEY=your-cortecs-api-key-here
CORTECS_BASE_URL=https://api.cortecs.ai/v1
CORTECS_CHAT_MODEL=deepseek-v4-pro
CORTECS_TRANSCRIPTION_MODEL=whisper-large-v3
CORTECS_PREFERENCE=balanced

# Mistral AI (kept for OCR + Voxtral TTS)
MISTRAL_API_KEY=your-mistral-api-key-here

# Mistral Voxtral TTS (live-translation audio injection + companion-tab).
# Both optional — sensible defaults are baked in.
#   MISTRAL_TTS_MODEL: only documented prod model id today is
#     voxtral-mini-tts-2603; override only if Mistral renames it.
#   MISTRAL_TTS_VOICE: pins ONE preset voice for every language. Leave
#     empty to use the per-language map (de_male, fr_male, …) with
#     casual_male as the multilingual fallback. Valid presets include
#     casual_male, casual_female, neutral_male, neutral_female,
#     cheerful_female, de_male, de_female, fr_male, it_male, …
# MISTRAL_TTS_MODEL=voxtral-mini-tts-2603
# MISTRAL_TTS_VOICE=
# TTS HTTP timeout + transient-failure retry (429 / 5xx / network).
# TTS_HTTP_TIMEOUT_MS=30000
# TTS_MAX_ATTEMPTS=3
# TTS_RETRY_BASE_MS=500

# Google Gemini
GEMINI_API_KEY=your-google-api-key-here

# Vexa Remote-Meeting integration (opt-in).
#
# To run Vexa Lite alongside GhostTyper, set COMPOSE_PROFILES=vexa and fill
# the variables below. Without the profile, none of these are read and the
# remote-meeting feature stays dormant — the in-app toggle in
# Settings → Integrationen → Vexa controls the second tier.
#
# Generate secrets with: openssl rand -hex 32
COMPOSE_PROFILES=
RECONCILE_API_SECRET=

# Shared secret for the document index backfill endpoint
# (POST /api/admin/documents/backfill-index, header X-BACKFILL-SECRET).
# Indexes pre-existing documents that have no completed index job yet, in
# bounded batches — safe to run repeatedly from a cron. Generate with
# `openssl rand -hex 32`. Leave empty to keep the endpoint disabled (it
# returns 401 when no secret is configured).
BACKFILL_API_SECRET=

# Server-side fallback URL used by GhostTyper when an org leaves the Vexa
# base URL empty in the integration settings. Defaults to the in-compose
# service name; only override for external Vexa deployments.
VEXA_BASE_URL=http://vexa-lite:8056

# Container image for the Vexa-Lite bot. Empty / unset = upstream
# Vexa-AI image (Google Meet, Microsoft Teams, Zoom only). To enable
# Nextcloud Talk support, set this to the forked image built by
# helge7925/vexa, e.g.:
#   VEXA_LITE_IMAGE=ghcr.io/helge7925/vexa-bot-talk:0.10.0-talk.1
# The fork tracks upstream and adds a fourth platform adapter; see
# https://github.com/helge7925/vexa/blob/feat/nextcloud-talk-adapter/UPSTREAM-SYNC.md
VEXA_LITE_IMAGE=

# Vexa-Dashboard (Operator-Tool) — Host-Port für die im vexa-lite-Image
# eingebaute Next.js-Dashboard-UI (Bot-Health, VNC, Live-Transcript).
# Standard-Bind ist 127.0.0.1, also nur lokal vom Server aus erreichbar
# (per SSH-Tunnel zugreifbar). Auth läuft über Vexa's admin-api-Token,
# NICHT über GhostTyper-NextAuth — also bewusst kein End-User-Tool.
VEXA_DASHBOARD_HOST_PORT=3300

# Bridge upstream override. Empty = default to Cortecs Whisper Large v3. Only set
# this if you want to point Vexa at a different Whisper-compatible API
# (must accept multipart POST /v1/audio/transcriptions with file/model/
# language and return segments with start/end/text/speaker_id).
VEXA_TRANSCRIPTION_URL=
# Legacy upstream-token fallback used by the bridge if CORTECS_API_KEY is
# not set. Prefer leaving this empty and using CORTECS_API_KEY (above).
VEXA_TRANSCRIPTION_TOKEN=

# Admin token for the Vexa container itself. Generate fresh:
#   openssl rand -hex 32
VEXA_ADMIN_API_TOKEN=

# Shared secret between the webapp and the transcription bridge container
# (the bridge directory is still named "fireworks-bridge" for historical
# reasons but routes to Mistral Voxtral by default — see
# docs/vexa-integration.md → "GDPR-konformes Setup"). Lets the bridge
# fetch the current Mistral Voxtral key (and workspace context bias) set
# in the admin UI at runtime.
#   openssl rand -hex 32
BRIDGE_SHARED_SECRET=
# Operator-managed fallback key used when no org-specific Cortecs key is
# resolved for a bridge transcription request.
BRIDGE_TRANSCRIPTION_API_KEY=
