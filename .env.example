# Database
DB_USER=transkription
DB_PASSWORD=change-me
DB_NAME=transkription
DATABASE_URL=postgresql://transkription:change-me@transkription-db:5432/transkription

# NextAuth
NEXTAUTH_SECRET=generate-a-random-secret
NEXTAUTH_URL=http://localhost:3000
AUTH_CREDENTIALS_ENABLED=false
OIDC_PROVIDER_NAME=Single Sign-On
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
DB_INIT_SECRET=separate-db-init-secret
SETTINGS_ENCRYPTION_KEY=separate-settings-encryption-key
ENABLE_DB_INIT_API=false
PDF_CHROMIUM_PATH=/usr/bin/chromium-browser
PDF_CHROMIUM_NO_SANDBOX=false
PDF_EXPORT_MAX_CONCURRENCY=2
PDF_EXPORT_QUEUE_TIMEOUT_MS=5000
TRANSCRIPTION_WORKER_CONCURRENCY=1
TRANSCRIPTION_WORKER_SCAN_INTERVAL_MS=8000
TRANSCRIPTION_WORKER_SCAN_BATCH=20
RATE_LIMIT_STORE=db
RATE_LIMIT_TRUST_PROXY=false
MAINTENANCE_IP_ALLOWLIST=
DB_CONNECTION_TIMEOUT_MS=5000
HTTP_CLIENT_TIMEOUT_MS=30000
HEALTH_DETAILS_PUBLIC=false
HEALTH_DETAILS_SECRET=
LOG_FORMAT=json
LOG_LEVEL=info

# Optional upload malware scan
UPLOAD_VIRUS_SCAN_MODE=command
UPLOAD_VIRUS_SCAN_CMD=clamscan --no-summary {file}
UPLOAD_VIRUS_SCAN_FAIL_OPEN=false
UPLOAD_VIRUS_SCAN_TIMEOUT_MS=20000

# API
NEXT_PUBLIC_API_URL=/api

# Mistral AI
MISTRAL_API_KEY=your-mistral-api-key-here

# Google Gemini
GEMINI_API_KEY=your-google-api-key-here
